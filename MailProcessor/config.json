{
  "imap": {
    "server": "imap.yandex.ru",
    "credentialTarget": "YandexMail",
    "port": 993,
    "sslOption": "Auto"
  },
  "processing": {
    "markAsRead": true,
    "daysToSearch": 7,
    "maxEmailsPerRun": 0,
    "outputFolder": "C:\\Output\\MailProcessor",
    "useDateSubfolder": false,
    "jsonFolder": "json",
    "saveAllMailsToJson": true
  },
  "attachments": [
    {
      "name": "PDF Documents",
      "enabled": true,
      "extensions": [ ".pdf" ],
      "subfolder": "attachments_pdf",
      "prefixWithUid": true,
      "saveMailToJson": true
    },
    {
      "name": "Excel Files",
      "enabled": true,
      "extensions": [ ".xls", ".xlsx" ],
      "subfolder": "attachments_excel",
      "prefixWithUid": true,
      "saveMailToJson": false
    }
  ],
  "tableParsing": {
    "enabled": true,
    "subfolder": "parsed",
    "parseAllTablesIfNoMatch": false,
    "saveMailToJson": false,
    "rules": [
      {
        "name": "TransferDetails",
        "tableIdentifier": "Сведения о переводе",
        "matchMode": "contains",
        "searchScope": "firstRow",
        "skipFirstRows": 1,
        "skipLastRows": 1,
        "includeHeader": false,
        "delimiter": ";"
      },
      {
        "name": "PaymentOrder",
        "tableIdentifier": "Платежное поручение",
        "matchMode": "contains",
        "searchScope": "firstRow",
        "skipFirstRows": 0,
        "skipLastRows": 0,
        "includeHeader": true,
        "delimiter": ";"
      }
    ]
  },
  "jsonExport": {
    "senderFilter": [],
    "subjectFilter": [],
    "includeBodyText": true,
    "includeBodyHtml": false,
    "createSummary": true
  },
  "logging": {
    "level": "info",
    "folder": "logs"
  }
}
