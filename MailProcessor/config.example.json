{
  // ═══════════════════════════════════════════════════════════════
  // MailProcessor — пример конфигурации с пояснениями
  // Файл поддерживает однострочные комментарии (// ...).
  // Скопируйте в config.json и заполните свои значения.
  // ═══════════════════════════════════════════════════════════════

  // ── IMAP: подключение к почтовому серверу ──
  "imap": {
    // Адрес IMAP-сервера (обязательно)
    // Примеры: "imap.yandex.ru", "imap.gmail.com", "imap.mail.ru"
    "server": "imap.yandex.ru",

    // Имя цели в Windows Credential Manager (обязательно)
    // Программа читает логин и пароль из Credential Manager
    // по этому имени. Создайте запись через:
    //   cmdkey /generic:"MyMailCreds" /user:"user@yandex.ru" /pass:"password"
    "credentialTarget": "YandexMail",

    // Порт IMAP-сервера.
    // 0 = авто-подбор (программа переберёт 993/143 с разными SSL-режимами).
    // Если знаете точный порт — укажите: обычно 993 для SSL, 143 для STARTTLS.
    "port": 0,

    // Режим SSL:
    //   "SslOnConnect" — SSL сразу при подключении (порт 993)
    //   "StartTls"     — STARTTLS после подключения (порт 143)
    //   "None"         — без шифрования (не рекомендуется)
    //   "Auto"         — авто-подбор (рекомендуется, если port = 0)
    "sslOption": "Auto"
  },

  // ── Обработка писем ──
  "processing": {
    // Помечать письма как прочитанные после обработки.
    // true — обработанные письма станут прочитанными в ящике.
    // false — письма останутся непрочитанными (при следующем запуске обработаются снова).
    "markAsRead": true,

    // Сколько последних дней просматривать.
    // 0 = все непрочитанные письма без ограничения по дате.
    "daysToSearch": 7,

    // Максимум писем за один запуск (0 = без лимита).
    // Полезно при первом запуске на ящике с тысячами писем.
    "maxEmailsPerRun": 0,

    // Базовая папка для сохранения результатов (обязательно).
    // Сюда сохраняются вложения (в подпапки групп) и CSV-файлы таблиц.
    "outputFolder": "C:\\Output\\MailProcessor",

    // Создавать подпапку с датой/временем запуска внутри outputFolder.
    // true — каждый запуск в отдельной папке: outputFolder\2026-06-03_14-30-00\
    // false — всё в одну папку (файлы перезаписываются при совпадении имён).
    "useDateSubfolder": false,

    // Путь до папки для JSON-файлов с метаданными писем.
    // Может быть:
    //   - Абсолютным путём: "C:\\Output\\MailProcessor\\json"
    //   - Относительным: считается подпапкой внутри outputFolder (или внутри датой-папки, если useDateSubfolder)
    //   - Пустой строкой: по умолчанию используется outputFolder\json
    "jsonFolder": "json",

    // Сохранять JSON-метаданные для ВСЕХ писем (независимо от наличия вложений/таблиц).
    // true — JSON создаётся для каждого обработанного письма (с учётом фильтров jsonExport).
    // false — JSON создаётся только для писем, подошедших под условия:
    //         - attachments[].saveMailToJson = true (есть вложения в этой группе)
    //         - tableParsing.saveMailToJson = true (найдена и распарсена таблица)
    "saveAllMailsToJson": false
  },

  // ── Группы вложений (массив) ──
  // Каждая группа задаёт свой набор расширений, свою подпапку
  // и свой флаг сохранения JSON. Это позволяет, например:
  //   - Сохранять JSON для писем с PDF, но не с Excel
  //   - Класть PDF в одну папку, а Excel — в другую
  //   - Временно отключить одну группу, не трогая остальные
  "attachments": [
    {
      // Человекочитаемое имя группы (для логов и JSON-метаданных).
      "name": "PDF Documents",

      // Включена ли эта группа. false — группа полностью пропускается.
      "enabled": true,

      // Расширения файлов, которые скачиваются в этой группе.
      // Внимание: расширения между группами не должны пересекаться —
      // иначе один и тот же файл будет сохранён несколько раз.
      "extensions": [ ".pdf" ],

      // Подпапка внутри outputFolder для файлов этой группы.
      "subfolder": "attachments_pdf",

      // Добавлять ли UID письма к имени файла.
      // true — файл: 123_1_document.pdf (UID_номер_имя)
      // false — файл: document.pdf (может перезаписаться при совпадении)
      "prefixWithUid": true,

      // Сохранять ли JSON-метаданные для писем, у которых есть
      // вложения из этой группы.
      // Пример: вы хотите JSON для писем с PDF, но не для писем с Excel.
      "saveMailToJson": true
    },
    {
      "name": "Excel Files",
      "enabled": true,
      "extensions": [ ".xls", ".xlsx" ],
      "subfolder": "attachments_excel",
      "prefixWithUid": true,
      // Для Excel — JSON не сохраняем (нам не нужна инфа о письмах с таблицами)
      "saveMailToJson": false
    }
    // Можно добавить ещё группы, например для .docx, .zip и т.д.
    // ,
    // {
    //   "name": "Word Documents",
    //   "enabled": false,
    //   "extensions": [ ".doc", ".docx" ],
    //   "subfolder": "attachments_word",
    //   "prefixWithUid": true,
    //   "saveMailToJson": false
    // }
  ],

  // ── Парсинг HTML-таблиц из тела письма ──
  // Если у письма нет вложений, подходящих ни под одну группу,
  // программа пытается найти и распарсить HTML-таблицы в теле письма.
  "tableParsing": {
    // Включён ли парсинг таблиц.
    "enabled": true,

    // Подпапка для CSV-файлов внутри outputFolder.
    "subfolder": "parsed",

    // Если ни одно правило не подошло — парсить ли все таблицы "как есть".
    // false — только таблицы, подошедшие под правила ниже.
    // true  — если правила не нашли таблицу, парсим все таблицы в HTML.
    "parseAllTablesIfNoMatch": false,

    // Сохранять ли JSON-метаданные для писем, у которых была
    // распарсена таблица (и сохранена в CSV).
    // true — JSON будет создан для таких писем (с учётом фильтров jsonExport).
    // false — JSON для писем с таблицами не создаётся
    //         (если только не включено saveAllMailsToJson или
    //          saveMailToJson в одной из групп вложений).
    "saveMailToJson": false,

    // Правила парсинга таблиц. Каждое правило описывает,
    // как найти нужную таблицу и какие строки из неё извлечь.
    "rules": [
      {
        // Имя правила — используется в логах и в именах CSV-файлов.
        "name": "TransferDetails",

        // Текст, по которому определяется нужная таблица.
        // Программа ищет этот текст в строках таблицы
        // (в зависимости от searchScope).
        "tableIdentifier": "Сведения о переводе",

        // Режим поиска tableIdentifier:
        //   "contains"   — строка содержит текст
        //   "startsWith" — строка начинается с текста
        //   "exact"      — точное совпадение (после нормализации пробелов)
        //   "regex"      — tableIdentifier — регулярное выражение
        "matchMode": "contains",

        // Где искать tableIdentifier:
        //   "firstRow" — только в первой строке таблицы
        //   "anyRow"   — в любой строке таблицы
        "searchScope": "firstRow",

        // Сколько строк пропустить сверху таблицы (0 = не пропускать).
        // Полезно, если перед данными есть заголовки или пустые строки.
        "skipFirstRows": 1,

        // Сколько строк пропустить снизу таблицы.
        "skipLastRows": 1,

        // Включать ли первую строку (после пропуска skipFirstRows) в CSV как заголовок.
        // false — первая строка пропускается, в CSV только данные.
        // true  — первая строка включается в CSV как заголовок.
        "includeHeader": false,

        // Разделитель столбцов в CSV-файле.
        "delimiter": ";"
      },
      {
        "name": "PaymentOrder",
        "tableIdentifier": "Платежное поручение",
        "matchMode": "contains",
        "searchScope": "firstRow",
        "skipFirstRows": 0,
        "skipLastRows": 0,
        "includeHeader": true,
        "delimiter": ";"
      }
    ]
  },

  // ── Настройки JSON-выгрузки (содержание и фильтры) ──
  // Само решение «сохранять ли JSON» управляется через:
  //   processing.saveAllMailsToJson       — для всех писем
  //   attachments[].saveMailToJson        — для писем с вложениями из группы
  //   tableParsing.saveMailToJson          — для писем с распарсенными таблицами
  // Здесь же — что именно включать в JSON и дополнительные фильтры.
  "jsonExport": {
    // Фильтр по отправителю.
    // Пустой массив [] — без фильтра, подходят все отправители.
    // Непустой — отправитель (email или имя) должен содержать
    // хотя бы одну из указанных строк (без учёта регистра).
    // Пример: ["@company.ru", "Иванов"] — письма от домена company.ru
    //         или от кого-то с фамилией Иванов.
    "senderFilter": [],

    // Фильтр по теме письма.
    // Пустой массив [] — без фильтра.
    // Непустой — тема письма должна содержать хотя бы одну из строк.
    // Пример: ["отчёт", "платёж"] — письма, в теме которых есть
    //         "отчёт" или "платёж".
    "subjectFilter": [],

    // Включать ли текстовое тело письма (plain text) в JSON.
    // Осторожно: может значительно увеличить размер JSON.
    "includeBodyText": true,

    // Включать ли HTML-тело письма в JSON.
    // Осторожно: HTML-письма могут быть очень большими.
    "includeBodyHtml": false,

    // Создавать ли сводный _summary.json со списком всех писем
    // и общей статистикой за запуск.
    "createSummary": true
  },

  // ── Логирование ──
  "logging": {
    // Уровень логирования:
    //   "debug" — максимум подробностей (для отладки)
    //   "info"  — стандартный уровень (рекомендуется)
    //   "error" — только ошибки
    "level": "info",

    // Папка для лог-файлов (относительно расположения exe).
    "folder": "logs"
  }
}
