{
  // ═══════════════════════════════════════════════════════════════
  // MailProcessor — пример конфигурации с пояснениями
  // Скопируйте в config.json и заполните свои значения.
  // ═══════════════════════════════════════════════════════════════

  "imap": {
    // Адрес IMAP-сервера (обязательно)
    "server": "imap.yandex.ru",

    // Имя цели в Windows Credential Manager (обязательно)
    "credentialTarget": "YandexMail",

    // Порт (0 = авто-подбор)
    "port": 0,

    // SSL-режим: "SslOnConnect" | "StartTls" | "None" | "Auto"
    "sslOption": "Auto",

    // IMAP-папка для обработки.
    // "INBOX" — основная папка (по умолчанию).
    // Можно указать подпапку: "INBOX/Reports", "Archive" и т.д.
    // Символ разделителя зависит от сервера (обычно / или .).
    "folder": "INBOX"
  },

  "processing": {
    "markAsRead": true,
    "daysToSearch": 7,
    "maxEmailsPerRun": 0,
    "outputFolder": "C:\\Output\\MailProcessor",
    "useDateSubfolder": true,
    "dateFormat": "yyyy-MM-dd_HH-mm-ss",
    "jsonFolder": "json",
    "saveAllMailsToJson": false,

    // Dry-run: показать что БЫЛО БЫ сделано, но не сохранять файлы
    // и не помечать письма как прочитанные. Полезно для проверки конфига.
    "dryRun": false
  },

  "attachments": [
    {
      "name": "PDF Documents",
      "enabled": true,
      "extensions": [ ".pdf" ],
      "subfolder": "attachments_pdf",
      "prefixWithUid": true,
      "saveMailToJson": true
    },
    {
      "name": "Excel Files",
      "enabled": true,
      "extensions": [ ".xls", ".xlsx" ],
      "subfolder": "attachments_excel",
      "prefixWithUid": true,
      "saveMailToJson": false
    }
  ],

  "tableParsing": {
    "enabled": true,
    "subfolder": "parsed",
    "parseAllTablesIfNoMatch": false,
    "saveMailToJson": false,
    "rules": [
      {
        "name": "TransferDetails",
        "tableIdentifier": "Сведения о переводе",
        "matchMode": "contains",
        "searchScope": "firstRow",
        "skipFirstRows": 1,
        "skipLastRows": 1,
        "includeHeader": false,
        "delimiter": ";",
        // Формат вывода таблицы:
        //   "csv"  — только CSV-файл (по умолчанию)
        //   "json" — только JSON-файл (с именованными полями, если есть заголовок)
        //   "both" — CSV и JSON одновременно
        "outputFormat": "csv"
      },
      {
        "name": "PaymentOrder",
        "tableIdentifier": "Платежное поручение",
        "matchMode": "contains",
        "searchScope": "firstRow",
        "skipFirstRows": 0,
        "skipLastRows": 0,
        "includeHeader": true,
        "delimiter": ";",
        "outputFormat": "both"
      }
    ]
  },

  "emailFilter": {
    "enabled": false,
    // Правила фильтрации писем. Правила объединяются по OR (достаточно одного совпадения).
    // Внутри правила: все непустые фильтры должны совпасть (AND).
    // Пустой patterns = любой отправитель / любая тема.
    // Фильтр — ДОПОЛНИТЕЛЬНАЯ причина сохранения JSON (не блокирует другие причины).
    "rules": [
      {
        // Имя правила (для логов)
        "name": "TestEmails",
        "sender": {
          "patterns": [],
          "matchMode": "contains"
        },
        "subject": {
          "patterns": [ "[тТ]ест" ],
          "matchMode": "regex"
        }
      },
      {
        "name": "CompanyReports",
        "sender": {
          "patterns": [ "@company.com" ],
          "matchMode": "contains"
        },
        "subject": {
          "patterns": [ "отчёт", "report" ],
          "matchMode": "contains"
        }
      }
    ]
  },

  "jsonExport": {
    "includeBodyText": true,
    "includeBodyHtml": false,
    "createSummary": true
  },

  "logging": {
    "level": "info",
    "folder": "logs"
  }
}
