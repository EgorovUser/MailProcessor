{
  // ═══════════════════════════════════════════════════════════════════════
  // MailProcessor — пример конфигурации с подробными пояснениями
  // ═══════════════════════════════════════════════════════════════════════
  //
  // 1. Скопируйте этот файл в config.json и заполните свои значения.
  // 2. config.json поддерживает // комментарии — они удаляются при загрузке.
  // 3. Все пути в конфиге могут использовать \\ (экранированный обратный слэш)
  //    или / (прямой слэш) — оба варианта работают в .NET.
  //
  // СТРУКТУРА КОНФИГА:
  //   imap          — подключение к IMAP-серверу
  //   processing    — общие настройки обработки (папки, даты, лимиты)
  //   attachments   — группы вложений (какие файлы скачивать)
  //   tableParsing  — парсинг HTML-таблиц из тела письма
  //   emailFilter   — правила фильтрации писем (доп. причина для JSON)
  //   jsonExport    — что включать в JSON-метаданные
  //   logging       — настройки логирования
  //
  // ЛОГИКА СОХРАНЕНИЯ JSON (три причины, объединённые по OR):
  //   JSON сохраняется, если ХОТЯ БЫ ОДНО из условий истинно:
  //     1) processing.saveAllMailsToJson = true       → сохранять ВСЕ письма
  //     2) группа вложений с saveMailToJson = true     → письмо с таким вложением
  //     3) письмо прошло emailFilter (enabled + rule)  → письмо подошло под фильтр
  //   То есть emailFilter — это ДОПОЛНИТЕЛЬНАЯ причина, а НЕ ограничение.
  // ═══════════════════════════════════════════════════════════════════════


  // ───────────────────────────────────────────────────────────────────────
  //  IMAP — подключение к почтовому серверу
  // ───────────────────────────────────────────────────────────────────────
  "imap": {

    // Адрес IMAP-сервера (ОБЯЗАТЕЛЬНОЕ поле).
    // Примеры для популярных провайдеров:
    //   Яндекс     → "imap.yandex.ru"
    //   Mail.ru    → "imap.mail.ru"
    //   Gmail      → "imap.gmail.com"
    //   Outlook    → "outlook.office365.com"
    //   Rambler    → "imap.rambler.ru"
    "server": "imap.yandex.ru",

    // Имя цели (target) в Windows Credential Manager (ОБЯЗАТЕЛЬНОЕ поле).
    // MailProcessor НЕ хранит пароль в конфиге — он берётся из Credential Manager.
    // Как создать:
    //   1) Откройте «Диспетчер учётных данных» (Credential Manager) в Windows
    //   2) «Учётные данные Windows» → «Добавить учётные данные»
    //   3) Адрес интернета или сети: введите значение этого поля (например, "YandexMail")
    //   4) Имя пользователя: ваш email (например, "user@yandex.ru")
    //   5) Пароль: пароль приложения (для Яндекс — сгенерируйте в настройках)
    "credentialTarget": "YandexMail",

    // Порт IMAP-сервера.
    //   0  → авто-подбор (993 для SSL, 143 без SSL) — РЕКОМЕНДУЕТСЯ
    //   993 → стандартный порт для IMAP over SSL
    //   143 → стандартный порт для IMAP без шифрования
    "port": 0,

    // Режим SSL/TLS-подключения.
    //   "SslOnConnect" — SSL с момента подключения (порт 993, стандартный вариант)
    //   "StartTls"     — сначала обычное подключение, затем TLS-апгрейд (порт 143)
    //   "None"         — без шифрования (ОПАСНО, только для локальных тестов)
    //   "Auto"         — авто-выбор по порту (993 → SslOnConnect, 143 → StartTls)
    "sslOption": "Auto",

    // Имя IMAP-папки для обработки (ОБЯЗАТЕЛЬНОЕ поле).
    //   "INBOX"           — основная папка «Входящие» (по умолчанию)
    //   "INBOX/Reports"   — подпапка «Отчёты» (разделитель / для большинства серверов)
    //   "Archive"         — папка «Архив»
    //   "Sent"            — папка «Отправленные»
    //   ВАЖНО: разделитель зависит от сервера (обычно / или .).
    //          Уточните разделитель в настройках вашего провайдера.
    "folder": "INBOX"
  },


  // ───────────────────────────────────────────────────────────────────────
  //  PROCESSING — общие настройки обработки писем
  // ───────────────────────────────────────────────────────────────────────
  "processing": {

    // Помечать ли письма как прочитанные после обработки.
    //   true  — письмо будет отмечено как прочитанное в почтовом ящике
    //           (при следующем запуске оно не будет обработано повторно)
    //   false — письма остаются непрочитанными (удобно для отладки:
    //           можно запускать обработку многократно)
    "markAsRead": true,

    // Сколько последних дней просматривать при поиске непрочитанных писем.
    //   0  → без ограничения по дате — обрабатывать ВСЕ непрочитанные письма
    //   1  → только письма за сегодня (полезно для частых запусков)
    //   7  → за последнюю неделю (значение по умолчанию)
    //   30 → за последний месяц
    "daysToSearch": 7,

    // Максимум писем за один запуск (0 = без лимита).
    //   0   → обрабатывать все найденные письма
    //   10  → обработать не более 10 писем (полезно для тестирования
    //         или для предотвращения перегрузки при большом скоплении почты)
    "maxEmailsPerRun": 0,

    // Базовая папка для сохранения результатов (ОБЯЗАТЕЛЬНОЕ поле).
    // Сюда сохраняются вложения, CSV, JSON-файлы и логи.
    // При включённом useDateSubfolder внутри создастся подпапка с датой.
    // Примеры:
    //   "C:\\Output\\MailProcessor"
    //   "D:\\Data\\Emails"
    //   "\\\\server\\share\\MailProcessor"   (сетевой путь)
    "outputFolder": "C:\\Output\\MailProcessor",

    // Создавать подпапку с датой/временем запуска внутри outputFolder.
    //   true  → файлы сохраняются в outputFolder\2025-06-09_14-30-00\
    //   false → файлы сохраняются прямо в outputFolder
    // РЕКОМЕНДУЕТСЯ true — каждый запуск в своей папке, нет риска перезаписи.
    "useDateSubfolder": true,

    // Формат даты/времени для имени подпапки и файлов (стандарт .NET format string).
    //   "yyyy-MM-dd_HH-mm-ss"  → 2025-06-09_14-30-00 (с секундами)
    //   "yyyy-MM-dd"            → 2025-06-09 (только дата)
    //   "yyyy-MM-dd_HH-mm"      → 2025-06-09_14-30 (без секунд)
    //   "yyyyMMdd_HHmmss"       → 20250609_143000 (компактный формат)
    "dateFormat": "yyyy-MM-dd_HH-mm-ss",

    // Имя подпапки для JSON-метаданных внутри basePath запуска.
    //   "json"       → JSON-файлы в папке basePath\json\
    //   ""           → JSON-файлы сохраняются прямо в basePath (без подпапки)
    //   "metadata"   → альтернативное имя подпапки
    "jsonFolder": "json",

    // Сохранять JSON-метаданные для ВСЕХ писем (независимо от вложений/таблиц/фильтров).
    //   true  — каждое обработанное письмо получает JSON-файл с метаданными
    //   false — JSON сохраняется только если есть хотя бы одна причина:
    //           • группа вложений с saveMailToJson=true
    //           • tableParsing.saveMailToJson=true и таблица найдена
    //           • письмо прошло emailFilter
    //   ВАЖНО: это причина №1 (из трёх), объединённая по OR с остальными.
    //          Если true — emailFilter и saveMailToJson не имеют значения (JSON уже сохранится).
    "saveAllMailsToJson": false,

    // Dry-run режим: имитация работы без реальных действий.
    //   true  — показать ЧТО БЫЛО БЫ сделано (в логах), но:
    //           • файлы НЕ сохраняются
    //           • письма НЕ помечаются как прочитанные
    //           • CSV/JSON НЕ создаются
    //   false — обычный режим (файлы сохраняются, письма помечаются)
    //   ИСПОЛЬЗУЙТЕ true для проверки конфига перед первым реальным запуском!
    "dryRun": false
  },


  // ───────────────────────────────────────────────────────────────────────
  //  ATTACHMENTS — группы вложений
  //  Массив групп. Каждая группа описывает, какие файлы скачивать.
  //  Письмо может попасть в несколько групп (например, .pdf и .xlsx).
  // ───────────────────────────────────────────────────────────────────────
  "attachments": [
    {
      // Человекочитаемое имя группы.
      // Используется в логах, именах файлов и JSON-метаданных.
      // Примеры: "PDF Documents", "Excel Reports", "Images", "Invoices"
      "name": "PDF Documents",

      // Включена ли эта группа.
      //   true  — вложения этой группы обрабатываются
      //   false — группа полностью пропускается (можно временно отключить)
      "enabled": true,

      // Расширения файлов, которые нужно скачивать (с точкой).
      // Регистр не имеет значения (.PDF = .pdf).
      // Примеры:
      //   [ ".pdf" ]                  — только PDF
      //   [ ".xls", ".xlsx" ]         — Excel обоих версий
      //   [ ".doc", ".docx" ]         — Word
      //   [ ".jpg", ".jpeg", ".png" ] — изображения
      //   [ ".zip", ".rar", ".7z" ]   — архивы
      "extensions": [ ".pdf" ],

      // Подпапка для вложений этой группы внутри basePath запуска.
      //   "attachments_pdf"    → basePath\attachments_pdf\
      //   "attachments_excel"  → basePath\attachments_excel\
      //   "docs"               → basePath\docs\
      "subfolder": "attachments_pdf",

      // Добавлять ли UID письма в начало имени файла.
      //   true  → "12345_document.pdf" (UID + подчёркивание + оригинальное имя)
      //   false → "document.pdf"       (только оригинальное имя)
      // РЕКОМЕНДУЕТСЯ true — UID гарантирует уникальность имени файла,
      //           т.к. разные письма могут иметь вложения с одинаковыми именами.
      "prefixWithUid": true,

      // Сохранять ли JSON-метаданные для писем, у которых есть вложения из этой группы.
      //   true  — если в письме есть вложение .pdf → JSON будет сохранён
      //   false — наличие PDF-вложения само по себе не вызывает сохранение JSON
      //   Это причина №2 (из трёх) для сохранения JSON, объединённая по OR.
      //   Если письмо подошло под emailFilter — JSON сохранится независимо от этого флага.
      "saveMailToJson": true
    },
    {
      "name": "Excel Files",
      "enabled": true,
      "extensions": [ ".xls", ".xlsx" ],
      "subfolder": "attachments_excel",
      "prefixWithUid": true,
      "saveMailToJson": false
    }
    // Можно добавить сколько угодно групп:
    // ,
    // {
    //   "name": "Images",
    //   "enabled": false,
    //   "extensions": [ ".jpg", ".jpeg", ".png", ".gif" ],
    //   "subfolder": "attachments_images",
    //   "prefixWithUid": true,
    //   "saveMailToJson": false
    // }
  ],


  // ───────────────────────────────────────────────────────────────────────
  //  TABLE PARSING — парсинг HTML-таблиц из тела письма
  //  Ищет таблицы в HTML-теле письма и извлекает их в CSV/JSON.
  //  Парсинг работает ТОЛЬКО если у письма НЕТ подходящих вложений
  //  (вложения имеют приоритет — письмо не обрабатывается дважды).
  // ───────────────────────────────────────────────────────────────────────
  "tableParsing": {

    // Включён ли парсинг таблиц.
    //   true  — письмо без вложений проверяется на наличие HTML-таблиц
    //   false — парсинг таблиц полностью отключён
    "enabled": true,

    // Подпапка для CSV/JSON файлов парсинга внутри basePath запуска.
    //   "parsed"  → basePath\parsed\
    //   "tables"  → basePath\tables\
    "subfolder": "parsed",

    // Если ни одно правило из rules не подошло — парсить ли ВСЕ таблицы из письма.
    //   true  — все HTML-таблицы будут извлечены (может быть шумно)
    //   false — извлекаются только таблицы, подошедшие под правила из rules
    "parseAllTablesIfNoMatch": false,

    // Сохранять ли JSON-метаданные для писем, у которых была распарсена таблица.
    //   true  — если таблица найдена и распарсена → JSON метаданных сохранится
    //   false — успешный парсинг таблицы сам по себе не вызывает сохранение JSON
    //   Это причина №2б (дополнение к причинам сохранения JSON), объединённая по OR.
    "saveMailToJson": false,

    // ─── Массив правил парсинга ───
    // Каждое правило описывает, какую таблицу искать и как её обрабатывать.
    // Правила проверяются по порядку. Первое совпадение — используется.
    // Если ни одно правило не совпало и parseAllTablesIfNoMatch=false —
    // таблицы не извлекаются.
    "rules": [
      {
        // Человекочитаемое имя правила.
        // Используется в логах и именах файлов (например, "12345_TransferDetails.csv").
        "name": "TransferDetails",

        // Текст для поиска нужной таблицы среди всех HTML-таблиц в письме.
        // Ищется в строках таблицы (в зависимости от searchScope).
        // Примеры:
        //   "Сведения о переводе"   — точный текст или подстрока (зависит от matchMode)
        //   "Платежное поручение"   — для банковских документов
        //   "Invoice"               — для англоязычных документов
        "tableIdentifier": "Сведения о переводе",

        // Режим поиска tableIdentifier в ячейках таблицы.
        //   "contains"   — содержит текст (частичное совпадение)
        //                   Пример: "перевод" совпадёт с "Сведения о переводе"
        //   "startsWith" — начинается с текста
        //                   Пример: "Сведения" совпадёт с "Сведения о переводе"
        //   "exact"      — точное совпадение (ячейка = tableIdentifier)
        //   "regex"      — регулярное выражение (синтаксис .NET Regex)
        //                   Пример: "Сведения\\s+о" совпадёт с "Сведения о переводе"
        "matchMode": "contains",

        // Где искать tableIdentifier в таблице.
        //   "firstRow" — только в первой строке таблицы (обычно заголовок)
        //   "anyRow"   — в любой строке таблицы
        "searchScope": "firstRow",

        // Сколько строк пропустить СВЕРХУ найденной таблицы (после заголовка).
        //   0 → не пропускать (сохранить все строки с первой)
        //   1 → пропустить первую строку (например, если это заголовок, а includeHeader=false)
        //   2 → пропустить первые две строки
        "skipFirstRows": 1,

        // Сколько строк пропустить СНИЗУ найденной таблицы.
        //   0 → не пропускать (сохранить все строки до последней)
        //   1 → пропустить последнюю строку (например, если это итоговая строка)
        //   2 → пропустить последние две строки
        "skipLastRows": 1,

        // Включать ли строку-заголовок в CSV/JSON вывод.
        //   true  → первая строка (после skipFirstRows) включается как заголовок
        //           В CSV: первая строка = имена столбцов
        //           В JSON: данные = массив объектов с именованными полями
        //   false → заголовок не включается
        //           В CSV: только данные (без строки заголовков)
        //           В JSON: данные = массив массивов (без имён полей)
        "includeHeader": false,

        // Разделитель столбцов для CSV-файла.
        //   ";"  — точка с запятой (стандарт для русскоязычного Excel)
        //   ","  — запятая (стандарт для англоязычного Excel)
        //   "\t" — табуляция
        "delimiter": ";",

        // Формат вывода распарсенной таблицы.
        //   "csv"  → только CSV-файл (по умолчанию)
        //            Пример: 12345_TransferDetails.csv
        //   "json" → только JSON-файл (с именованными полями при includeHeader=true)
        //            Пример: 12345_TransferDetails.json
        //   "both" → CSV и JSON одновременно
        //            Пример: 12345_TransferDetails.csv + 12345_TransferDetails.json
        "outputFormat": "csv"
      },
      {
        "name": "PaymentOrder",
        "tableIdentifier": "Платежное поручение",
        "matchMode": "contains",
        "searchScope": "firstRow",
        "skipFirstRows": 0,
        "skipLastRows": 0,
        "includeHeader": true,
        "delimiter": ";",
        "outputFormat": "both"
      }
      // Можно добавить ещё правила:
      // ,
      // {
      //   "name": "InvoiceItems",
      //   "tableIdentifier": "^Invoice\\s+#\\d+",  // regex
      //   "matchMode": "regex",
      //   "searchScope": "anyRow",
      //   "skipFirstRows": 2,
      //   "skipLastRows": 0,
      //   "includeHeader": true,
      //   "delimiter": ",",
      //   "outputFormat": "both"
      // }
    ]
  },


  // ───────────────────────────────────────────────────────────────────────
  //  EMAIL FILTER — правила фильтрации писем
  //
  //  НАЗНАЧЕНИЕ: emailFilter — это ДОПОЛНИТЕЛЬНАЯ причина для сохранения
  //  JSON-метаданных. Он НЕ блокирует другие причины (saveAllMailsToJson,
  //  saveMailToJson), а добавляет ещё одну.
  //
  //  ЛОГИКА:
  //    • Правила (rules) объединяются по OR — достаточно совпадения одного правила
  //    • Внутри правила: все непустые фильтры (sender, subject) должны совпасть (AND)
  //    • Пустой patterns у фильтра = «любое значение» (фильтр не учитывается)
  //
  //  ПРИМЕРЫ КОМБИНАЦИЙ:
  //    Правило { sender: "@company.com", subject: [] }
  //      → ЛЮБОЕ письмо от @company.com (тема любая)
  //
  //    Правило { sender: [], subject: "[тТ]ест" }
  //      → ЛЮБОЕ письмо с темой, совпадающей с regex (отправитель любой)
  //
  //    Правило { sender: "@bank.ru", subject: "Выписка" }
  //      → Только письма от @bank.ru И с темой, содержащей "Выписка"
  //        (ОБА условия должны совпасть)
  //
  //    Два правила:
  //      rules: [
  //        { sender: "@bank.ru", subject: "Выписка" },
  //        { sender: "@tax.ru", subject: [] }
  //      ]
  //      → Письмо проходит, если:
  //         (от @bank.ru И тема содержит "Выписка") ИЛИ (от @tax.ru)
  // ───────────────────────────────────────────────────────────────────────
  "emailFilter": {

    // Включён ли фильтр писем.
    //   true  — правила проверяются; совпадение = причина для сохранения JSON
    //   false — правила НЕ проверяются; emailFilter не влияет на обработку
    "enabled": false,

    // Массив правил фильтрации. Письмо проходит, если подходит ХОТЯ БЫ ПОД ОДНО правило.
    "rules": [
      {
        // Человекочитаемое имя правила (для логов).
        // Примеры: "TestEmails", "CompanyReports", "BankNotifications"
        "name": "TestEmails",

        // ─── Фильтр по отправителю ───
        // Проверяется и email-адрес, и имя отправителя (объединённая строка).
        // Пример: если отправитель "Иван <ivan@company.com>",
        //         проверяемая строка = "ivan@company.com Иван"
        "sender": {
          // Шаблоны для сопоставления. Пустой массив = любой отправитель.
          // При matchMode="contains"/"startsWith"/"exact":
          //   достаточно совпадения с ОДНИМ из шаблонов (OR внутри patterns)
          // При matchMode="regex":
          //   каждый шаблон — отдельное регулярное выражение
          // Примеры:
          //   []                          → любой отправитель
          //   [ "@company.com" ]          → содержит "@company.com"
          //   [ "@bank.ru", "@bank.com" ] → содержит "@bank.ru" ИЛИ "@bank.com"
          "patterns": [],

          // Режим сопоставления (одинаковый для sender и subject).
          //   "contains"   — содержит подстроку (частичное совпадение, без учёта регистра)
          //   "startsWith" — начинается с текста
          //   "exact"      — точное совпадение
          //   "regex"      — регулярное выражение (.NET Regex, без учёта регистра)
          "matchMode": "contains"
        },

        // ─── Фильтр по теме письма ───
        // Проверяется строка темы (Subject) письма.
        "subject": {
          // Шаблоны для сопоставления. Пустой массив = любая тема.
          // Примеры:
          //   []                           → любая тема
          //   [ "отчёт" ]                  → тема содержит "отчёт"
          //   [ "отчёт", "report" ]        → тема содержит "отчёт" ИЛИ "report"
          //   [ "[тТ]ест" ]                → regex: тема содержит "Тест" или "тест"
          //   [ "^\\[URGENT\\]" ]          → regex: тема начинается с "[URGENT]"
          "patterns": [ "[тТ]ест" ],

          "matchMode": "regex"
        }
      },
      {
        "name": "CompanyReports",
        "sender": {
          // Совпадёт с любым отправителем, чей адрес содержит "@company.com"
          // Например: "director@company.com", "hr@company.com"
          "patterns": [ "@company.com" ],
          "matchMode": "contains"
        },
        "subject": {
          // Совпадёт, если тема содержит "отчёт" ИЛИ "report"
          // (два шаблона в patterns = OR между ними)
          "patterns": [ "отчёт", "report" ],
          "matchMode": "contains"
        }
        // ИТОГО для этого правила: (отправитель содержит @company.com)
        //                         И (тема содержит "отчёт" ИЛИ "report")
      }
    ]
    // Можно добавить ещё правила:
    // ,
    // {
    //   "name": "BankNotifications",
    //   "sender": {
    //     "patterns": [ "@bank.ru" ],
    //     "matchMode": "contains"
    //   },
    //   "subject": {
    //     "patterns": [ "^Выписка по счёту" ],  // regex: тема начинается с "Выписка по счёту"
    //     "matchMode": "regex"
    //   }
    // },
    // {
    //   "name": "AllFromTaxOffice",
    //   "sender": {
    //     "patterns": [ "@nalog.gov.ru", "@fns.gov.ru" ],  // два домена
    //     "matchMode": "contains"
    //   },
    //   "subject": {
    //     "patterns": [],  // пустой = любая тема
    //     "matchMode": "contains"
    //   }
    //   // ИТОГО: (отправитель содержит @nalog.gov.ru ИЛИ @fns.gov.ru) И (тема любая)
    // }
  },


  // ───────────────────────────────────────────────────────────────────────
  //  JSON EXPORT — содержание JSON-метаданных
  //  Настраивает, какие данные включать в JSON-файлы писем.
  // ───────────────────────────────────────────────────────────────────────
  "jsonExport": {

    // Включать ли текстовое (plain text) тело письма в JSON.
    //   true  → поле body.plainText содержит текст письма
    //   false → поле body.plainText отсутствует (экономит размер файла)
    //   ВНИМАНИЕ: текстовые письма могут быть очень большими.
    //             Если JSON-файлы нужны только для метаданных — установите false.
    "includeBodyText": true,

    // Включать ли HTML-тело письма в JSON.
    //   true  → поле body.html содержит HTML-код письма
    //   false → поле body.html отсутствует (РЕКОМЕНДУЕТСЯ — HTML может быть огромным)
    //   ВНИМАНИЕ: HTML-письма часто содержат встроенные стили, картинки (base64)
    //             и могут увеличивать размер JSON в десятки раз.
    "includeBodyHtml": false,

    // Создавать ли сводный _summary.json со всеми письмами запуска.
    //   true  → файл _summary.json содержит:
    //           • runInfo — информация о запуске (дата, конфиг, сервер)
    //           • stats   — статистика (обработано, пропущено, ошибки)
    //           • groups  — статистика по группам вложений
    //           • results — распределение по статусам
    //           • emails  — массив метаданных всех писем
    //   false → сводный файл не создаётся
    "createSummary": true
  },


  // ───────────────────────────────────────────────────────────────────────
  //  LOGGING — настройки логирования
  // ───────────────────────────────────────────────────────────────────────
  "logging": {

    // Уровень детализации логирования.
    //   "debug" → максимальная детализация: все шаги обработки,
    //             совпадения фильтров, подробности парсинга таблиц.
    //             ИСПОЛЬЗУЙТЕ при отладке конфигурации.
    //   "info"  → стандартный уровень: основные события обработки
    //             (найденные письма, сохранённые файлы, итоги).
    //             РЕКОМЕНДУЕТСЯ для повседневного использования.
    //   "error" → только ошибки (минимальный вывод).
    "level": "info",

    // Подпапка для логов (относительно директории exe-файла).
    //   "logs"      → logs\ (рядом с MailProcessor.exe)
    //   "log"       → log\
    //   ""          → логи сохраняются в текущую директорию
    "folder": "logs"
  }
}